# Hoist all transitive deps to each package's top-level node_modules.
#
# Required because the Electron app's deref-workspace-deps build step copies
# packages/sync/ as a real directory into apps/desktop/node_modules/@nestbrain/sync/.
# With pnpm's default (strict) layout, packages/sync/node_modules/ holds only
# direct symlinks (chokidar) — its transitive deps (readdirp, anymatch, ...) live
# one level above in node_modules/.pnpm/chokidar@*/node_modules/ and don't come
# along when we cp -R the workspace into the asar.
#
# shamefully-hoist makes pnpm also resolve sibling transitive deps next to each
# package's direct ones, so a `dereference: true` copy is self-contained at the
# package's tree root. This is the documented fix for electron-builder + pnpm.
shamefully-hoist=true
