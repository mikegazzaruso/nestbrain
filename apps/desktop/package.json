{
  "name": "@nestbrain/desktop",
  "version": "1.14.3",
  "private": true,
  "description": "NestBrain native desktop app",
  "main": "dist/main.js",
  "scripts": {
    "ensure-oauth-config": "node build/ensure-oauth-config.mjs",
    "ensure-update-config": "node build/ensure-update-config.mjs",
    "bundle-updater": "node build/bundle-updater.mjs",
    "dereference-workspace-deps": "node build/dereference-workspace-deps.mjs",
    "build:ts": "pnpm ensure-oauth-config && pnpm ensure-update-config && tsc -p tsconfig.json && pnpm bundle-updater",
    "build": "pnpm build:ts",
    "dev": "pnpm build:ts && NESTBRAIN_DEV=1 electron .",
    "start": "electron .",
    "package": "pnpm dereference-workspace-deps && electron-builder",
    "package:mac": "pnpm dereference-workspace-deps && electron-builder --mac",
    "package:win": "pnpm dereference-workspace-deps && electron-builder --win"
  },
  "dependencies": {
    "@nestbrain/shared": "workspace:*",
    "@nestbrain/sync": "workspace:*",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "@types/node": "^20.19.39",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-updater": "^6.3.9",
    "esbuild": "^0.24.0",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "com.nextepochs.nestbrain",
    "productName": "NestBrain",
    "copyright": "Copyright © 2026 NextEpochs",
    "npmRebuild": false,
    "afterPack": "build/after-pack.cjs",
    "compression": "normal",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "node_modules/node-pty/**/*",
      "!**/*.d.ts.map",
      "!**/*.d.cts.map",
      "!**/*.d.mts.map"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "extraResources": [
      {
        "from": "../../apps/web/.next/standalone",
        "to": "web"
      },
      {
        "from": "../../skeleton",
        "to": "skeleton"
      },
      {
        "from": "build/cli",
        "to": "cli"
      }
    ],
    "publish": {
      "provider": "generic",
      "url": "https://updates.nestbrain.app"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": true
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "differentialPackage": false,
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "include": "build/installer.nsh"
    }
  }
}
